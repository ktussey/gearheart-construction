---
interface Props {
  label: string;
  title: string;
  subtitle: string;
  image: string;
  imageAlt: string;
  minHeight?: string;
}

const { label, title, subtitle, image, imageAlt, minHeight } = Astro.props;
---

<section class="page-hero" style={minHeight ? `min-height: ${minHeight};` : undefined}>
  <div class="page-hero__bg">
    <img src={image} alt={imageAlt} />
    <div class="page-hero__overlay"></div>
  </div>
  <div class="container">
    <div class="page-hero__content">
      <div class="section-label" style="color: var(--gold);">{label}</div>
      <h1 class="page-hero__title">{title}</h1>
      <p class="page-hero__subtitle">{subtitle}</p>
    </div>
  </div>
</section>
